      <aliases enabled='yes' />
      <column caption='Patient Count' datatype='integer' name='[Calculation_294282134550650880]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Patient ID])' />
      </column>
      <column caption='Event Label' datatype='string' name='[Calculation_294282134551646209]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Event (death: 1, alive: 0)] = 1 THEN &quot;Death&quot; ELSE &quot;Alive&quot; END' />
      </column>
      <column caption='Death Rate' datatype='real' name='[Calculation_294282134551715842]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Event (death: 1, alive: 0)])' />
      </column>
      <column caption='Survival (Years)' datatype='real' name='[Calculation_294282134551760899]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Survival time (days)] / 365.25' />
      </column>
      <column caption='EGFR Group' datatype='string' name='[Calculation_294282134551834628]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([EGFR], &quot;Exon&quot;) THEN &quot;EGFR+&quot; ELSE &quot;EGFR-&quot; END' />
      </column>
      <column caption='KRAS Group' datatype='string' name='[Calculation_294282134551912453]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [KRAS] = &quot;Negative&quot; THEN &quot;KRAS-&quot; ELSE &quot;KRAS+&quot; END' />
      </column>
      <column caption='Egfr' datatype='string' name='[EGFR]' role='dimension' type='nominal' />
      <column caption='Kras' datatype='string' name='[KRAS]' role='dimension' type='nominal' />
